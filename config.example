# Claude Slack Gateway Configuration
# Copy this to 'config' and fill in your values

# Slack Bot Token (from OAuth & Permissions page)
SLACK_BOT_TOKEN="xoxb-your-token-here"

# Default channel name (without #)
SLACK_DEFAULT_CHANNEL="claude-bot"

# Channel ID (get this by sending a test message)
SLACK_DEFAULT_CHANNEL_ID="C0XXXXXXXXX"

# Allowed user ID (only this user can send commands)
# Find this in Slack: Profile → ... → Copy member ID
ALLOWED_USER_ID="U0XXXXXXXXX"
